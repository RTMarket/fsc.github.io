// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//
// ============================================================================
// 核心数据模型 - B2B 跨境采购平台
// 功能：工厂-卖家 双向采购，分销佣金，资质认证，回款冻结规则
//
// ============================================================================
// 用户 - 基础表 (包括采购商卖家和工厂供应商)
model User {
  id String @id @default(cuid())
  email String? @unique
  phone String? @unique
  passwordHash String
  name String? // 企业名称
  avatar String?
  type UserType
  // 身份认证
  realName String? // 法人姓名
  idCardFront String? // 身份证正面
  idCardBack String? // 身份证背面
  businessLicense String? // 营业执照
  isVerified Boolean @default(false)
  // 分销相关
  referrerId String? // 邀请人ID (分销)
  // Stripe 相关
  stripeAccountId String? // Stripe 账户 ID
  stripeConnected Boolean @default(false)
  // 通用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive Boolean @default(true)
  // 关系
  referrer User? @relation("Referral", fields: [referrerId], references: [id])
  referrals User[] @relation("Referral")
  products Product[]
  orders Order[]
  messagesSent Message[] @relation("SentMessages")
  messagesReceived Message[] @relation("ReceivedMessages")
  certificates ProductCertificate[]
  // 工厂成长等级
  factoryLevel String? // 根据订单量自动升级
  totalOrders Int @default(0)
  // 买家信用评分
  creditScore Int? // 综合信用分 (0-100)
  // 地址
  country String?
  state String?
  city String?
  zipCode String?
  address String?
  // 联系人信息
  contactName String?
  contactPhone String?
  // 工厂专属
  ein String? // 美国 EIN 税号
  rfc String? // 墨西哥 RFC
  warehousePhotos String[]
  supportDropship Boolean @default(false)
}

enum UserType {
  BUYER // 中国跨境采购卖家
  FACTORY // 美国/墨西哥本土工厂供应商
  ADMIN // 平台管理员
}

// 产品类目 - 层级化
model Category {
  id String @id @default(cuid())
  name String // 类目名称
  slug String @unique // URL 别名
  parentId String?
  parent Category? @relation("Subcategories", fields: [parentId], references: [id])
  subcategories Category[] @relation("Subcategories")
  // 资质要求 - 这个类目是否需要产品资质证书
  requireCertificate Boolean @default(false)
  certificateDescription String? // 提示需要什么资质
  // 排序
  sortOrder Int @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products Product[]
}

// 产品
model Product {
  id String @id @default(cuid())
  factoryId String
  factory User @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  categoryId String
  category Category @relation(fields: [categoryId], references: [id])
  // 基本信息
  title String // 产品标题
  description String // 产品描述
  // 价格库存
  fobPrice Decimal // FOB 价格 (美元)
  stock Int // 库存数量
  // 发货信息
  shippingState String? // 发货州
  processingDays Int // 处理天数 1-3
  // 图片
  mainImage String // 主图
  images String[] // 副图 (最多 9 张)
  // 规格
  hasVariants Boolean @default(false)
  // 状态
  isActive Boolean @default(true)
  isApproved Boolean @default(false) // 平台审核
  rejectedReason String?
  // 统计
  totalSales Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // 关系
  variants ProductVariant[]
  // 资质证书
  certificates ProductCertificate[]
  // 订单
  orderItems OrderItem[]
  // 评价
  reviews ProductReview[]
}

// 产品规格变体
model ProductVariant {
  id String @id @default(cuid())
  productId String
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name String // 规格名称 (e.g. "颜色")
  value String // 规格值 (e.g. "红色")
  price Decimal? // 加价，如果不同规格价格不同
  stock Int // 该规格库存
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 产品资质证书
model ProductCertificate {
  id String @id @default(cuid())
  productId String?
  factoryId String
  factory User @relation(fields: [factoryId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  // 证书信息
  certificateType String // 认证类型 (e.g. "UL", "FDA", "DOT")
  certificateNumber String // 证书编号
  issuingAuthority String // 颁发机构
  validFrom DateTime? // 生效日期
  validTo DateTime? // 到期日期
  certificateFile String // 证书文件 URL
  isApproved Boolean @default(false) // 平台审核
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 订单
model Order {
  id String @id @default(cuid())
  orderNumber String @unique // FSC + 11位数字
  buyerId String
  buyer User @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  // 收货信息
  shippingCountry String @default("US")
  shippingState String
  shippingCity String
  shippingZipCode String
  shippingAddress String
  contactName String
  contactPhone String
  // 价格信息
  subtotal Decimal // 商品总价
  shippingFee Decimal // 运费
  platformFee Decimal // 平台佣金 (3%-6%)
  depositAmount Decimal // 保证金 5%
  totalAmount Decimal // 总计
  // 分销佣金
  referrerId String? // 分销邀请人
  referrerCommission Decimal @default(0) // 1% 佣金
  // 状态
  status OrderStatus
  // 售后
  hasAfterSale Boolean @default(false)
  afterSaleStatus AfterSaleStatus?
  // 回款规则 - 冻结机制
  // 80% 立即到账，20% T+5 冻结
  // 如果售后，每一个未解决售后 +5 天冻结
  releasedPercentage Int @default(0) // 已释放百分比
  nextReleaseDate DateTime? // 下次可释放时间
  isFullyReleased Boolean @default(false)
  // 物流
  trackingNumber String?
  carrier String?
  // 确认收货
  confirmedAt DateTime?
  // 售后
  aftersaleStartedAt DateTime?
  // 通用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items OrderItem[]
  afterSales AfterSale[]
  commission ReferrerCommission?
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

// 订单项
model OrderItem {
  id String @id @default(cuid())
  orderId String
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product Product
  // 信息快照
  productTitle String
  productImage String
  variant String?
  price Decimal
  quantity Int
  createdAt DateTime @default(now())
}

// 售后/退货
model AfterSale {
  id String @id @default(cuid())
  orderId String
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type AfterSaleType
  reason String
  // 证据
  photos String[]
  // 状态
  status AfterSaleStatus
  // 工厂处理
  factoryDecision FactoryDecision?
  factoryNote String?
  processedAt DateTime?
  // 退款信息
  refundAmount Decimal?
  // 日期
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AfterSaleType {
  RETURN_REFUND // 退货退款
  EXCHANGE // 换货
  ONLY_REFUND // 仅退款
}

enum AfterSaleStatus {
  PENDING // 等待工厂审核
  APPROVED // 通过
  REJECTED // 驳回
  PROCESSING // 处理中
  COMPLETED // 完成
}

enum FactoryDecision {
  APPROVE
  REJECT
}

// 分销佣金记录
model ReferrerCommission {
  id String @id @default(cuid())
  referrerId String
  referrer User @relation(fields: [referrerId], references: [id])
  orderId String
  order Order @relation(fields: [orderId], references: [id])
  amount Decimal
  isPaid Boolean @default(false)
  paidAt DateTime?
  createdAt DateTime @default(now())
}

// 产品评价
model ProductReview {
  id String @id @default(cuid())
  productId String
  orderId String
  buyerId String
  buyer User @relation(fields: [buyerId], references: [id])
  rating Int // 1-5 星
  content String?
  photos String[]
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 私信消息
model Message {
  id String @id @default(cuid())
  senderId String
  sender User @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content String
  // 检测违禁联系方式
  hasContactInfo Boolean @default(false)
  isRead Boolean @default(false)
  createdAt DateTime @default(now())
}

// 通知
model Notification {
  id String @id @default(cuid())
  userId String
  title String
  content String
  type String
  isRead Boolean @default(false)
  link String?
  createdAt DateTime @default(now())
}

// 平台配置 - 佣金比例等
model PlatformConfig {
  id String @id @default(cuid())
  key String @unique
  value Json
  description String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
